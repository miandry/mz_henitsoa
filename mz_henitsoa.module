use Drupal\Core\Routing\RouteMatchInterface;
use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Entity\EntityInterface;
use Drupal\Core\Url;
use Drupal\node\NodeInterface;

/**
* Implements hook_help().
 */
function mz_henitsoa_help($route_name, RouteMatchInterface $route_match) {
    switch ($route_name) {
        // Main module help for the mz_henitsoa module.
        case 'help.page.mz_henitsoa':
            $output = '';
            $output .= '<h3>' . t('About') . '</h3>';
            $output .= '<p>' . t('mz_henitsoa entity api') . '</p>';
            return $output;
        default:
    }
}

/**
 * Implements hook_entity_operation().
 */
function mz_henitsoa_entity_operation_alter(array &$operations, EntityInterface $entity) {
    $entityTypeId = $entity->getEntityTypeId();
    $bundle = $entity->bundle();
    $id = $entity->id();
    if($entityTypeId == 'node' && $bundle == 'inscription'){
            $editUrl = Url::fromRoute('mz_henitsoa.controller' ,
                ['id' => $id ]);
            $operations['download_carnet'] = array(
                'title' => t('Telecharger le carnet'),
                'weight' => 20,
                'url' => $editUrl,
            );
    }else{
          return ;
    }
}
/**
 * Implements hook_form_BASE_FORM_ID_alter().
 */
function mz_henitsoa_form_alter(&$form, FormStateInterface $form_state, $form_id) {

  if($form_id == 'node_inscription_edit_form'){
     $form['title']['widget'][0]['value']['#attributes'] = ['readonly' => 'readonly'];
     $form['field_ecolage_status']['#attributes']['class'][] = 'readonly-checkboxes';
    
  }
   if($form_id == 'node_inscription_form' ){
      $date = new DateTime();
      $dateFormatted = $date->format('Ymd');
      $uniqueId = uniqid();
      $randomId = $dateFormatted . '_' . $uniqueId;
      $form['title']['widget'][0]['value']['#default_value'] =   $randomId;
      $form['title']['#attributes'] = ['style' => 'display:none'];
      $form['field_ecolage_status']['#attributes']['class'][] = 'readonly-checkboxes';
      $form['#validate'][] = '_unique_inscript_validate';

   }
   if($form_id == 'node_ecolage_form'){
      $date = new DateTime();
      $dateFormatted = $date->format('Ymd');
      $uniqueId = uniqid();
      $randomId = $dateFormatted . '_' . $uniqueId;
      $form['title']['widget'][0]['value']['#default_value'] =   $randomId;
      $form['title']['#attributes'] = ['style' => 'display:none'];
      $form['#validate'][] = '_unique_title_validate';
   }
   if($form_id == 'node_ecolage_edit_form'){
      $form['#validate'][] = '_unique_title_validate';
   }
}

/**
 * Custom validation handler for node titles.
 */
function _unique_inscript_validate($form, FormStateInterface $form_state) {
  $an_id = $form_state->getValue('field_annee_scolaire')[0]['value'];
  $el_id = $form_state->getValue('field_eleve')[0]['target_id'];
  $eleve = \Drupal::entityTypeManager()->getStorage('node')->load( $el_id );
  $service = \Drupal::service('mz_henitsoa.default');
  $name = $service->getFullName($eleve);
  $status = $service->checkifInscrExist(  $el_id  , $an_id );
  if ($status) {
    $form_state->setErrorByName('field_eleve', t("L'élève @el pour le annee scolaire de @an existe déjà."  , ['@el' =>   $name,'@an' => $an_id ]));
  }
}
/**
 * Custom validation handler for node titles.
 */
function _unique_title_validate($form, FormStateInterface $form_state) {
  $mois_id = $form_state->getValue('field_mois')[0]['target_id'];
  $inscript_id = $form_state->getValue('field_inscrit')[0]['target_id'];
  $mois = \Drupal::entityTypeManager()->getStorage('node')->load($mois_id);
  $ins = \Drupal::entityTypeManager()->getStorage('node')->load($inscript_id);

  $mois_name =    $mois->label() ;
  $inscr_name =    $ins->label() ;
  $status = \Drupal::service('mz_henitsoa.default')->checkifEcolageExist($inscript_id , $mois_id );
  // If a node with the same title exists, set a form error.
  if ($status) {
    $form_state->setErrorByName('field_mois', t('Ecolage pour le mois de @mois de @el existe déjà.'  , ['@el' =>   $inscr_name,'@mois' => $mois_name ]));
  }
}

