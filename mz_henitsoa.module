/**
 * Implements hook_ENTITY_TYPE_presave().
 *
 * Save the first value of field_article_tags to field_article_main_tag.
 *
 * @param \Drupal\node\NodeInterface $node
 */

 function mz_henitsoa_node_presave(NodeInterface $node) {
      if($node->bundle() == "inscription"){
        $eleve =  $node->field_eleve->entity ;
        $title =  $eleve->field_nom->value ." ".$eleve->field_prenom->value ;
        $node->title->value = $title ;
      }

    

 }
 function mz_henitsoa_node_delete(NodeInterface $node) {
  if($node->bundle() == "ecolage"){
    $ins = $node->field_inscrit->entity;
    \Drupal::service('mz_henitsoa.default')->unCheckEcolage($ins , $node);
  }
 }
 function mz_henitsoa_node_insert(NodeInterface $node) {
  if($node->bundle() == "ecolage"){
    $ins = $node->field_inscrit->entity;
    \Drupal::service('mz_henitsoa.default')->checkEcolage($ins , $node);
  }
 }
 function mz_henitsoa_node_update(NodeInterface $node) {
  if($node->bundle() == "ecolage"){
    $ins = $node->field_inscrit->entity;
    \Drupal::service('mz_henitsoa.default')->checkEcolage($ins , $node);
  }
 }

/**
 * Implements hook_page_attachments_alter().
 *
 * Disables pinch-zoom on the henitsoaapp Vue.js shell (/app/*) so it feels
 * like a native mobile app, without changing the viewport behavior of the
 * rest of the site (core sets a permissive viewport meta tag by default).
 */
function mz_henitsoa_page_attachments_alter(array &$page) {
  $route_name = \Drupal::routeMatch()->getRouteName();
  if (!in_array($route_name, ['mz_henitsoa.app', 'mz_henitsoa.app_subpath'], TRUE)) {
    return;
  }
  foreach ($page['#attached']['html_head'] as &$item) {
    if (($item[1] ?? '') === 'viewport') {
      $item[0]['#attributes']['content'] = 'width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no';
    }
  }
}


